  "version": 4,
  "configurations": [
    {
      "name": "Mac",
      "includePath": [
        "${workspaceFolder}/**",
        "${env:HOME}/vcpkg/installed/arm64-osx/include",
        "${env:HOME}/vcpkg/installed/arm64-osx/include/opencv4",
